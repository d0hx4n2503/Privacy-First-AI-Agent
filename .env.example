# ============================================================
# Privacy-first AI Agent for DeFi — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ── Hedera ──────────────────────────────────────────────────
# Get Testnet Account at: https://portal.hedera.com/register
HEDERA_NETWORK=testnet
HEDERA_OPERATOR_ID=0.0.XXXXXXX
HEDERA_OPERATOR_KEY=302e020100300506032b657004220420...

# ── 0G ──────────────────────────────────────────────────────
# Export from MetaMask. Faucet: https://faucet.0g.ai/
ZG_PRIVATE_KEY=0x...
ZG_RPC_URL=https://evmrpc-testnet.0g.ai
ZG_STORAGE_URL=https://api.0g.ai/storage
ZG_COMPUTE_URL=https://api.0g.ai/compute

# ── Uniswap ─────────────────────────────────────────────────
# Get API Key at: https://developers.uniswap.org/
UNISWAP_API_KEY=your_uniswap_api_key
UNISWAP_API_BASE_URL=https://api.uniswap.org/v2
# Wallet (MetaMask) for Unichain testnet execution:
TRADER_PRIVATE_KEY=0x...
TRADER_CHAIN_ID=11155111

# ── Chainlink CRE ───────────────────────────────────────────
# DON url for testnet simulation
CRE_DON_URL=https://don.testnet.chainlink.io
CRE_WORKFLOW_ID=
CRE_SIGNING_KEY=0x...

# ── Naryo / RPC ─────────────────────────────────────────────
HEDERA_MIRROR_NODE_URL=https://testnet.mirrornode.hedera.com
HEDERA_JSON_RPC_URL=https://testnet.hashio.io/api
UNICHAIN_RPC_URL=https://sepolia.unichain.org
ETHEREUM_RPC_URL=https://rpc.sepolia.org

# ── iNFT / 0G Contract ──────────────────────────────────────
INFT_CONTRACT_ADDRESS=0x...
AGENT_REGISTRY_ADDRESS=0.0.XXXXXXX
PRIVACY_VAULT_ADDRESS=0.0.XXXXXXX

# ── General ─────────────────────────────────────────────────
# Set to true for dry-run (no real transactions)
DRY_RUN=false
LOG_LEVEL=info
