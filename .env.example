PRIVACY_VAULT_ADDRESS=0x1238536071E1c677A632429e3655c799b22cDA52

# ─── 0G LABS (DECENTRALIZED INFRA) ────────────────────────────────
# RPC for 0G Chain (EVM side)
ZG_RPC_URL=https://evmrpc-testnet.0g.ai
# Storage Indexer / RPC (Ankr or official)
ZG_INDEXER_URL=https://rpc.ankr.com/eth_sepolia
# Compute API for Sealed Inference (TEE)
ZG_COMPUTE_URL=https://api-compute.testnet.0g.ai
# 🧠 AI Fallback Brains (Optional)
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o
# Private Key for 0G transactions (Storage/Compute)
ZG_PRIVATE_KEY=your_0g_private_key_here

# ─── UNISWAP & ETHEREUM (DEFI) ────────────────────────────────────
# RPC for Unichain Sepolia or Ethereum Sepolia
ETHEREUM_RPC_URL=https://sepolia.unichain.org
UNICHAIN_RPC_URL=https://sepolia.unichain.org
# Private Key for trading (USDC/ETH swaps)
TRADER_PRIVATE_KEY=your_trader_private_key_here
# Uniswap Routing API (Optional, uses heuristic if empty)
UNISWAP_API_KEY=
UNISWAP_API_BASE_URL=https://api.uniswap.org/v2

# ─── CHAINLINK (ORCHESTRATION) ────────────────────────────────────
# Chainlink CRE DON URL
CRE_DON_URL=https://don.testnet.chainlink.io

# ─── EXECUTION FLAGS ──────────────────────────────────────────────
# Set to 'true' to bypass real blockchain transactions
DRY_RUN=false
# Set to 'true' for synthetic event generation in demo
SIMULATE=false
# Set to 'debug' for verbose logs
LOG_LEVEL=info
MOCK_USER_INPUT=false
