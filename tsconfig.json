{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@naryo/*": ["src/naryo/*"],
      "@agent/*": ["src/agent/*"],
      "@chainlink-cre/*": ["src/chainlink/*"],
      "@hedera/*": ["src/hedera/*"],
      "@uniswap-module/*": ["src/uniswap/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "contracts"]
}
